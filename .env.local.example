POSTGRES_PASSWORD=<generate-a-local-postgres-password>
DATABASE_URL=postgresql://<db_user>:<db_password>@localhost:5432/levelfit?schema=public
REDIS_URL=redis://localhost:6380
API_PORT=3001
API_HOST=127.0.0.1
WEB_ORIGIN=http://127.0.0.1:3000
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/v1
JWT_ACCESS_SECRET=<generate-with-openssl-rand-base64-32>
JWT_ISSUER=levelfit-api
JWT_AUDIENCE=levelfit-web
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
TOKEN_HASH_SECRET=<generate-a-different-openssl-rand-base64-32>
SWAGGER_ENABLED=true
NODE_ENV=development
