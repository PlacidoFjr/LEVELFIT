{
  "name": "levelfit",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev": "next dev",
    "dev:api": "npm run dev -w @levelfit/api",
    "build:api": "npm run build -w @levelfit/api",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:deploy": "node scripts/deploy-db.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "user:verify": "tsx scripts/verify-user.ts",
    "verify": "npm run lint && npm run typecheck && npm run typecheck -w @levelfit/api && npm test -w @levelfit/api && npm run build && npm run build:api",
    "infra:up": "docker compose up -d postgres redis",
    "infra:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "7.8.0",
    "animejs": "^4.5.0",
    "dotenv": "17.2.3",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.1.0",
    "framer-motion": "12.42.2",
    "lucide-react": "0.546.0",
    "next": "16.2.10",
    "prisma": "7.8.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.9.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "4.3.3",
    "tsx": "4.23.1",
    "typescript": "5.9.3"
  }
}
