generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  pending_email
  deleted
}

enum FitnessGoal {
  consistency
  strength
  conditioning
  weight_management
  hydration
  nutrition
}

enum ActivityLevel {
  beginner
  returning
  occasional
  active
}

enum WorkoutDifficulty {
  easy
  medium
  hard
}

enum WorkoutCategory {
  strength
  cardio
  mobility
  full_body
  recovery
}

enum SessionStatus {
  planned
  in_progress
  completed
  skipped
  cancelled
}

enum SessionExerciseStatus {
  pending
  completed
  skipped
}

enum MissionType {
  workout
  water
  nutrition
  habit
  progress
  recovery
}

enum MissionStatus {
  pending
  completed
  missed
  skipped
}

enum XpReason {
  mission_completed
  workout_completed
  water_goal_completed
  nutrition_checklist_completed
  achievement_unlocked
  streak_saved
  recovery_completed
}

enum AchievementCategory {
  first_steps
  workout
  water
  nutrition
  streak
  progress
  recovery
}

enum AchievementRarity {
  common
  uncommon
  rare
  epic
}

enum StreakType {
  daily
  workout
  water
  nutrition
}

enum StreakStatus {
  active
  at_risk
  saved
  broken
}

enum NotificationType {
  mission_pending
  workout_today
  water_incomplete
  nutrition_incomplete
  streak_at_risk
  achievement_unlocked
  daily_summary
  weekly_summary
  security_alert
  reactivation
}

enum NotificationChannel {
  in_app
  email
  push
}

enum DeliveryStatus {
  queued
  sent
  delivered
  failed
  bounced
}

enum ScheduledStatus {
  pending
  sent
  cancelled
  failed
}

enum SecurityEventType {
  login_success
  login_failed
  suspicious_login
  password_changed
  email_changed
  two_factor_enabled
  two_factor_disabled
  sessions_revoked
  data_export_requested
  account_deletion_requested
}

enum UnitSystem {
  metric
  imperial
}

enum ThemePreference {
  dark
  light
  system
}

enum PaymentProvider {
  stripe
  mercadopago
  app_store
  play_store
}

enum SubscriptionStatus {
  trialing
  active
  past_due
  cancelled
  expired
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum ProfessionalKind {
  nutrition
  run
}

enum ProfessionalConnectionStatus {
  active
  revoked
}

enum UserAccessRole {
  OWNER
  NUTRITIONIST
  RUN_COACH
}

model User {
  id                     String     @id @default(uuid()) @db.Uuid
  email                  String     @unique @db.Citext
  passwordHash           String?    @map("password_hash")
  emailVerifiedAt        DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  status                 UserStatus @default(active)
  sensitiveDataConsentAt DateTime?  @map("sensitive_data_consent_at") @db.Timestamptz(6)
  termsAcceptedAt        DateTime?  @map("terms_accepted_at") @db.Timestamptz(6)
  marketingOptIn         Boolean    @default(false) @map("marketing_opt_in")
  rankingOptIn           Boolean    @default(false) @map("ranking_opt_in")
  lastLoginAt            DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt              DateTime?  @map("deleted_at") @db.Timestamptz(6)

  profile                 UserProfile?
  authAccounts            AuthAccount[]
  sessions                Session[]
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  securityEvents          UserSecurityEvent[]
  createdWorkouts         Workout[]                 @relation("CreatedWorkouts")
  workoutSessions         WorkoutSession[]
  foodLogs                FoodLog[]
  nutritionGoals          NutritionGoal[]
  waterLogs               WaterLog[]
  hydrationGoals          HydrationGoal[]
  userMissions            UserMission[]
  xpEvents                XpEvent[]
  level                   UserLevel?
  achievements            UserAchievement[]
  streaks                 Streak[]
  bodyMeasurements        BodyMeasurement[]
  progressPhotos          ProgressPhoto[]
  notifications           Notification[]
  notificationPreference  NotificationPreference?
  emailLogs               EmailLog[]
  pushSubscriptions       PushSubscription[]
  scheduledNotifications  ScheduledNotification[]
  preferences             UserPreference?
  subscriptions           Subscription[]
  payments                Payment[]
  auditLogsAsActor        AuditLog[]                @relation("AuditActor")
  auditLogsAsTarget       AuditLog[]                @relation("AuditTarget")
  professionalConnections ProfessionalConnection[]
  roleAssignments         UserRoleAssignment[]      @relation("UserRoleSubject")
  assignedRoleAssignments UserRoleAssignment[]      @relation("UserRoleAssigner")

  @@index([status])
  @@index([deletedAt])
  @@map("users")
}

model UserRoleAssignment {
  id               String         @id @default(uuid()) @db.Uuid
  userId           String         @map("user_id") @db.Uuid
  role             UserAccessRole
  source           String         @default("manual") @db.VarChar(32)
  assignedByUserId String?        @map("assigned_by_user_id") @db.Uuid
  revokedAt        DateTime?      @map("revoked_at") @db.Timestamptz(6)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  user       User  @relation("UserRoleSubject", fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User? @relation("UserRoleAssigner", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([userId, role, revokedAt])
  @@index([role, revokedAt])
  @@map("user_role_assignments")
}

model UserProfile {
  id            String         @id @default(uuid()) @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  displayName   String         @map("display_name") @db.VarChar(120)
  birthDate     DateTime?      @map("birth_date") @db.Date
  gender        String?        @db.VarChar(40)
  heightCm      Decimal?       @map("height_cm") @db.Decimal(5, 2)
  fitnessGoal   FitnessGoal?   @map("fitness_goal")
  activityLevel ActivityLevel? @map("activity_level")
  avatarUrl     String?        @map("avatar_url")
  timezone      String         @default("UTC") @db.VarChar(80)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt     DateTime?      @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([fitnessGoal])
  @@map("user_profiles")
}

model AuthAccount {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  provider          String    @db.VarChar(40)
  providerAccountId String    @map("provider_account_id") @db.VarChar(160)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("auth_accounts")
}

model Session {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  deviceName    String?   @map("device_name") @db.VarChar(160)
  ipHash        String?   @map("ip_hash")
  userAgentHash String?   @map("user_agent_hash")
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([userId, revokedAt])
  @@map("sessions")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  sessionId String    @map("session_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  rotatedAt DateTime? @map("rotated_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model UserSecurityEvent {
  id            String            @id @default(uuid()) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  type          SecurityEventType
  ipHash        String?           @map("ip_hash")
  userAgentHash String?           @map("user_agent_hash")
  metadata      Json              @default("{}")
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@map("user_security_events")
}

model WorkoutPlan {
  id          String         @id @default(uuid()) @db.Uuid
  title       String         @db.VarChar(160)
  description String?
  goal        FitnessGoal?
  level       ActivityLevel?
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?      @map("deleted_at") @db.Timestamptz(6)

  workouts Workout[]

  @@map("workout_plans")
}

model Workout {
  id              String            @id @default(uuid()) @db.Uuid
  planId          String?           @map("plan_id") @db.Uuid
  title           String            @db.VarChar(160)
  description     String?
  difficulty      WorkoutDifficulty
  estimatedMinutes Int              @map("estimated_minutes")
  category        WorkoutCategory
  isPublic        Boolean           @default(false) @map("is_public")
  createdByUserId String?           @map("created_by_user_id") @db.Uuid
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?         @map("deleted_at") @db.Timestamptz(6)

  plan          WorkoutPlan?     @relation(fields: [planId], references: [id])
  createdByUser User?            @relation("CreatedWorkouts", fields: [createdByUserId], references: [id])
  exercises     WorkoutExercise[]
  sessions      WorkoutSession[]

  @@index([difficulty])
  @@index([category])
  @@index([planId])
  @@map("workouts")
}

model Exercise {
  id           String    @id @default(uuid()) @db.Uuid
  name         String    @db.VarChar(160)
  muscleGroup  String    @map("muscle_group") @db.VarChar(80)
  equipment    String?   @db.VarChar(80)
  instructions String?
  safetyNotes  String?   @map("safety_notes")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)

  workouts WorkoutExercise[]
  sessionExercises WorkoutSessionExercise[]

  @@index([name])
  @@index([muscleGroup])
  @@map("exercises")
}

model WorkoutExercise {
  id          String   @id @default(uuid()) @db.Uuid
  workoutId   String   @map("workout_id") @db.Uuid
  exerciseId  String   @map("exercise_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  targetSets  Int?     @map("target_sets")
  targetReps  Int?     @map("target_reps")
  targetSeconds Int?   @map("target_seconds")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutId, exerciseId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSession {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @map("user_id") @db.Uuid
  workoutId       String        @map("workout_id") @db.Uuid
  startedAt       DateTime      @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?     @map("completed_at") @db.Timestamptz(6)
  status          SessionStatus @default(planned)
  perceivedEffort Int?          @map("perceived_effort")
  notes           String?
  xpAwarded       Int           @default(0) @map("xp_awarded")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  user      User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout                  @relation(fields: [workoutId], references: [id])
  exercises WorkoutSessionExercise[]

  @@index([userId, startedAt])
  @@index([status])
  @@map("workout_sessions")
}

model WorkoutSessionExercise {
  id              String                @id @default(uuid()) @db.Uuid
  sessionId       String                @map("session_id") @db.Uuid
  exerciseId      String                @map("exercise_id") @db.Uuid
  setsCompleted   Int                   @default(0) @map("sets_completed")
  repsCompleted   Int?                  @map("reps_completed")
  weightKg        Decimal?              @map("weight_kg") @db.Decimal(6, 2)
  durationSeconds Int?                  @map("duration_seconds")
  status          SessionExerciseStatus @default(pending)
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id])

  @@index([sessionId])
  @@index([exerciseId])
  @@map("workout_session_exercises")
}

model Meal {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(80)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  foodLogs FoodLog[]

  @@map("meals")
}

model Food {
  id              String    @id @default(uuid()) @db.Uuid
  tacoCode        Int?      @unique @map("taco_code")
  name            String    @db.VarChar(180)
  searchName      String    @map("search_name") @db.VarChar(220)
  category        String    @db.VarChar(100)
  kcalPer100g     Int?      @map("kcal_per_100g")
  proteinGPer100g Decimal?  @map("protein_g_per_100g") @db.Decimal(7, 2)
  carbsGPer100g   Decimal?  @map("carbs_g_per_100g") @db.Decimal(7, 2)
  fatGPer100g     Decimal?  @map("fat_g_per_100g") @db.Decimal(7, 2)
  fiberGPer100g   Decimal?  @map("fiber_g_per_100g") @db.Decimal(7, 2)
  source          String    @db.VarChar(120)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz(6)

  foodLogItems FoodLogItem[]

  @@index([searchName])
  @@index([category])
  @@map("foods")
}

model FoodLog {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @map("user_id") @db.Uuid
  mealId                String?   @map("meal_id") @db.Uuid
  loggedAt              DateTime  @default(now()) @map("logged_at") @db.Timestamptz(6)
  description           String?
  hasProtein            Boolean?  @map("has_protein")
  hasFruitOrVegetable   Boolean?  @map("has_fruit_or_vegetable")
  avoidedSkippingMeal   Boolean?  @map("avoided_skipping_meal")
  mindfulChoice         Boolean?  @map("mindful_choice")
  calories              Int?
  proteinG              Decimal?  @map("protein_g") @db.Decimal(6, 2)
  carbsG                Decimal?  @map("carbs_g") @db.Decimal(6, 2)
  fatG                  Decimal?  @map("fat_g") @db.Decimal(6, 2)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt             DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  meal Meal? @relation(fields: [mealId], references: [id])
  items FoodLogItem[]

  @@index([userId, loggedAt])
  @@index([mealId])
  @@map("food_logs")
}

model FoodLogItem {
  id           String   @id @default(uuid()) @db.Uuid
  foodLogId    String   @map("food_log_id") @db.Uuid
  foodId       String?  @map("food_id") @db.Uuid
  nameSnapshot String   @map("name_snapshot") @db.VarChar(180)
  quantityG    Decimal  @map("quantity_g") @db.Decimal(7, 2)
  calories     Int?
  proteinG     Decimal? @map("protein_g") @db.Decimal(7, 2)
  carbsG       Decimal? @map("carbs_g") @db.Decimal(7, 2)
  fatG         Decimal? @map("fat_g") @db.Decimal(7, 2)
  fiberG       Decimal? @map("fiber_g") @db.Decimal(7, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  foodLog FoodLog @relation(fields: [foodLogId], references: [id], onDelete: Cascade)
  food    Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  @@index([foodLogId])
  @@index([foodId])
  @@map("food_log_items")
}

model NutritionGoal {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  dailyCalories      Int?      @map("daily_calories")
  proteinG           Decimal?  @map("protein_g") @db.Decimal(6, 2)
  carbsG             Decimal?  @map("carbs_g") @db.Decimal(6, 2)
  fatG               Decimal?  @map("fat_g") @db.Decimal(6, 2)
  checklistGoalCount Int       @default(3) @map("checklist_goal_count")
  startsOn           DateTime  @map("starts_on") @db.Date
  endsOn             DateTime? @map("ends_on") @db.Date
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsOn])
  @@map("nutrition_goals")
}

model WaterLog {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  amountMl  Int       @map("amount_ml")
  loggedAt  DateTime  @default(now()) @map("logged_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedAt])
  @@map("water_logs")
}

model HydrationGoal {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  dailyGoalMl Int       @map("daily_goal_ml")
  startsOn    DateTime  @map("starts_on") @db.Date
  endsOn      DateTime? @map("ends_on") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsOn])
  @@map("hydration_goals")
}

model DailyMission {
  id          String      @id @default(uuid()) @db.Uuid
  key         String      @unique @db.VarChar(120)
  title       String      @db.VarChar(160)
  description String
  type        MissionType
  xpReward    Int         @map("xp_reward")
  isActive    Boolean     @default(true) @map("is_active")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime?   @map("deleted_at") @db.Timestamptz(6)

  userMissions UserMission[]

  @@index([type])
  @@index([isActive])
  @@map("daily_missions")
}

model UserMission {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  dailyMissionId String        @map("daily_mission_id") @db.Uuid
  missionDate    DateTime      @map("mission_date") @db.Date
  status         MissionStatus @default(pending)
  completedAt    DateTime?     @map("completed_at") @db.Timestamptz(6)
