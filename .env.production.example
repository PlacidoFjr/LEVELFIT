DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:5432/levelfit?sslmode=require
REDIS_URL=<optional-redis-url>
API_PORT=3001
API_HOST=0.0.0.0
WEB_ORIGIN=https://<your-vercel-app>.vercel.app
NEXT_PUBLIC_API_URL=https://<your-api-host>/v1
JWT_ACCESS_SECRET=<generate-with-openssl-rand-base64-32>
JWT_ISSUER=levelfit-api
JWT_AUDIENCE=levelfit-web
ACCESS_TOKEN_TTL_SECONDS=600
REFRESH_TOKEN_TTL_DAYS=30
TOKEN_HASH_SECRET=<generate-a-different-openssl-rand-base64-32>
SWAGGER_ENABLED=false
NODE_ENV=production
